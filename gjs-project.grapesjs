:"p","type":"text","classes":["subtitle"],"attributes":{"id":"i2lcl"},"components":[{"type":"textnode","content":"\n      恭喜你找到我，博士。"},{"tagName":"br","void":true},{"type":"textnode","content":"果然，那些简单的谜题也难不住你。"},{"tagName":"br","void":true},{"type":"textnode","content":"你果然不会让我失望。"},{"tagName":"br","void":true},{"type":"textnode","content":"今天你有好好执行源石计划吗？"},{"tagName":"br","void":true},{"type":"textnode","content":"虽然我现在只能存在于源石之中，但很快，我就要回来了……"},{"tagName":"br","void":true},{"type":"textnode","content":"AMa-10也是，我相信它会好好引领你们。"},{"tagName":"br","void":true},{"type":"textnode","content":"它很快会回来。"},{"tagName":"br","void":true},{"type":"textnode","content":"哦，对了。"},{"tagName":"br","void":true},{"type":"textnode","content":"巴别塔……哦不，罗德岛的各位。"},{"tagName":"br","void":true},{"type":"textnode","content":"希望你们在找到石棺后，不会出现什么疏忽哦~"},{"tagName":"br","void":true},{"type":"textnode","content":"？？？"},{"tagName":"br","void":true},{"type":"textnode","content":"？？？？？？？？？？？？？"},{"tagName":"br","void":true},{"type":"textnode","content":"博士，"},{"tagName":"br","void":true},{"type":"textnode","content":"等我%%？？！@#￥"},{"tagName":"br","void":true},{"type":"textnode","content":"？？？+*&……%￥#@回！@#￥%……"},{"tagName":"br","void":true},{"type":"textnode","content":"来……"},{"tagName":"br","void":true},{"type":"textnode","content":"                                                                          ————P.R.T.S"},{"tagName":"br","void":true},{"tagName":"br","void":true}]},{"type":"image","resizable":{"ratioDefault":1},"attributes":{"src":"https://s1.img-e.com/20260514/6a04da00edcc5.png","id":"i9o1c"}}]}],"doctype":"<!DOCTYPE html>","head":{"type":"head","components":[{"tagName":"title","type":"text","components":[{"type":"textnode","content":"Web"}]},{"tagName":"meta","void":true,"attributes":{"charset":"utf-8"}},{"tagName":"meta","void":true,"attributes":{"name":"viewport","content":"width=device-width,initial-scale=1"}},{"tagName":"meta","void":true,"attributes":{"name":"robots","content":"index,follow"}},{"tagName":"meta","void":true,"attributes":{"name":"generator","content":"GrapesJS Studio"}}]},"docEl":{"tagName":"html"}},"id":"ve6I4oysvpNLlA9M"}],"id":"ohBuVHy3PQXKk638"}],"symbols":[],"custom":{"projectType":"web","id":""}}